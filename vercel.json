{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/health", "dest": "/api/health.js" },
    { "src": "/api/customer-orders", "dest": "/api/customer-orders.js" },
    { "src": "/api/orders/([^/]+)", "dest": "/api/orders/[clientId].js?clientId=$1" },
    { "src": "/(.*\\.(?:css|js))", "dest": "/$1" },
    { "src": "/order.html", "dest": "/order.html" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
